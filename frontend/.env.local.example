# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
# Must match the URL your frontend runs on (no trailing slash)
NEXTAUTH_URL=http://localhost:5000

# ── Backend API ───────────────────────────────────────────────────────────────
# Used by the browser (client-side requests)
NEXT_PUBLIC_API_URL=http://localhost:8000/api
# Used by NextAuth server-side (credentials login, OAuth exchange)
# Must be set separately — NEXT_PUBLIC_ vars are not available server-side at runtime
API_URL=http://localhost:8000/api

# ── OAuth Providers ───────────────────────────────────────────────────────────
# Google — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub — https://github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Push Notifications (optional) ────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
