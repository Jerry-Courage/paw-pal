{
  "version": 2,
  "builds": [
    {
      "src": "backend/core/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.12" }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    { 
      "src": "/api/auth/(login|signup|me|logout|refresh|verify|register|profile|status)(.*)", 
      "dest": "backend/core/wsgi.py" 
    },
    { "src": "/api/auth/(.*)", "dest": "/api/auth/$1" },
    { "src": "/api/(?!auth)(.*)", "dest": "backend/core/wsgi.py" },
    { "src": "/admin/(.*)", "dest": "backend/core/wsgi.py" },
    { "src": "/(.*)", "dest": "frontend/$1" }
  ]
}
